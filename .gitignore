# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/

# compiled TypeScript output — Render builds this on deploy
dist/

# next.js build output
.next/
/out/
/build

# testing
/coverage

# misc
.DS_Store
*.pem

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — DO commit .env.example files, DO NOT commit .env / .env.local
.env
.env.local
.env.development
.env.production
.env.test
# Allow example files to be committed:
!.env.example

# large binary / data files at repo root
*.pdf
menuItems.json

# vercel
.vercel

# typescript incremental build info
*.tsbuildinfo
next-env.d.ts
