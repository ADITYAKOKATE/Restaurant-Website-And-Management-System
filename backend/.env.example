# ──────────────────────────────────────────────────────────────────
# Premacha Wada — Backend Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit the .env file to git.
# ──────────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=production

# MongoDB Atlas connection string
# Get this from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/premacha-wada?retryWrites=true&w=majority

# JWT Secret — use a long random string (e.g. openssl rand -hex 32)
JWT_SECRET=replace_with_a_strong_random_secret

# Frontend URL(s) — comma-separated, no trailing slash
# For local dev only:   http://localhost:3000
# For production:       https://your-app.vercel.app
# Both together:        http://localhost:3000,https://your-app.vercel.app
FRONTEND_URL=https://your-app.vercel.app
